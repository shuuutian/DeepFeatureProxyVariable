{
    "n_repeat": 5,
    "data": {
        "name": "demand",
        "n_sample": 100,
        "missing_rate": 0.3,
        "preprocess": "Identity"
    },
    "model": {
        "name": "dfpv_mar_modified",
        "lam1": [0.03, 0.1, 0.3],
        "lam2": [0.03, 0.1, 0.3],
        "stage1_iter": 20,
        "stage2_iter": 1,
        "n_epoch": 80,
        "n_folds": 3,
        "nuisance_n_epochs": [20, 50],
        "propensity_clip": [0.0001, 0.001, 0.01],
        "split_ratio": 0.5,
        "treatment_weight_decay": 0.1,
        "treatment_proxy_weight_decay": 0.1,
        "outcome_proxy_weight_decay": 0.1,
        "backdoor_weight_decay": 0.0
    }
}
